{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(*)"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf ..*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .git*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(truncate *)",
      "Bash(chmod -R 777*)",
      "Bash(chmod 777 *)",
      "Bash(* > /dev/*)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.preview)",
      "Read(**/.env.staging)",
      "Read(**/.env.test)",
      "Read(**/.envrc)",
      "Read(**/.ssh/**)",
      "Read(**/id_ed25519*)",
      "Read(**/id_rsa*)"
    ]
  }
}
